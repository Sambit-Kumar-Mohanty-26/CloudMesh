# Non-superuser cloudmesh_app role — RLS-bound. See packages/db/.env.example.
APP_DATABASE_URL="postgresql://cloudmesh_app:cloudmesh_app@localhost:55432/cloudmesh"

# Superuser — not used by normal request handling, only present for parity
# with the other services' env shape.
DATABASE_URL="postgresql://cloudmesh:cloudmesh@localhost:55432/cloudmesh"

REDIS_URL="redis://localhost:6379"

PORT=3001

# All provider keys are optional — omit any you don't have. A request
# routed to a provider with no key configured fails that one request with
# a clear error, the gateway still boots fine.
OPENAI_API_KEY=
OPENAI_BASE_URL="https://api.openai.com"

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_VERSION="2023-06-01"

GEMINI_API_KEY=
GEMINI_BASE_URL="https://generativelanguage.googleapis.com"

OLLAMA_BASE_URL="http://localhost:11434"

# Set true to register the no-network "mock-echo" model for local testing
# without any real provider credentials.
ENABLE_MOCK_PROVIDER=true

IDEMPOTENCY_TTL_SECONDS=86400
