# Non-superuser cloudmesh_app role — RLS-bound. See packages/db/.env.example.
APP_DATABASE_URL="postgresql://cloudmesh_app:cloudmesh_app@localhost:55432/cloudmesh"

# Superuser — used ONLY by test setup/teardown to reset fixtures. The
# running server never touches this in normal request handling.
DATABASE_URL="postgresql://cloudmesh:cloudmesh@localhost:55432/cloudmesh"

REDIS_URL="redis://localhost:6379"

PORT=3000

# Must be >= 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET="dev-only-secret-change-me-please-32chars-min"

# Optional — set during a secret rotation so tokens signed with the old
# secret still verify for the overlap window. Unset once rotation completes.
JWT_SECRET_PREVIOUS=

BCRYPT_COST=12
