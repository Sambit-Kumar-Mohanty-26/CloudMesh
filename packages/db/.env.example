# Superuser — migrations, seeding, test fixtures ONLY. Bypasses RLS.
DATABASE_URL="postgresql://cloudmesh:cloudmesh@localhost:55432/cloudmesh"

# Non-superuser cloudmesh_app role — this is what running services connect
# with. RLS-bound: see packages/db/prisma/migrations/*_app_role.
APP_DATABASE_URL="postgresql://cloudmesh_app:cloudmesh_app@localhost:55432/cloudmesh"
